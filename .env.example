DATABASE_URL=postgresql://user:password@localhost:5432/fedsight

# FEMA OpenAPI
FEMA_API_URL=https://www.fema.gov/api/open/v2/DisasterDeclarationsSummaries
FEMA_PAGE_SIZE=1000

# USAspending API
USASPENDING_API_URL=https://api.usaspending.gov/api/v2/disaster/spending_by_geography/
USASPENDING_DEF_CODES=L,M,N,O,P,U

# Risk score weights (must sum to 1.0)
RISK_WEIGHT_DISASTER_COUNT=0.30
RISK_WEIGHT_RECENT_ACTIVITY=0.35
RISK_WEIGHT_HURRICANE_EXPOSURE=0.25
RISK_WEIGHT_SPENDING_GAP=0.10
